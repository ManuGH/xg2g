# ==============================================================================
# xg2g Artifacts Policy - Clean by Construction
# ==============================================================================
# All ephemeral build/test outputs must be routed to these directories.
/artifacts/
/build/
tmp/
logs/
.runtime-bin/
!logs/.gitkeep
!logs/test_artifacts/.gitkeep

# Standard Go/Build Artifacts
build-ffmpeg.sh
ffmpeg-wrapper.sh
ffprobe-wrapper.sh
bin/
pkg/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.prof
*.pid
*.lock
!/DIGESTS.lock
*.tmp
*.bk
*.bak

# Specific Build Files (Repo Root)
/xg2g
/xg2g-*
/backend/xg2g-daemon
/daemon
/daemon-*
/v3probe
/validate
/api.test
/test_output.txt
/test_report.txt
test_*.txt
*.log
*_logs.txt
debug*.txt
vuln*.txt
test_output*.txt
test_results*.txt
coverage.out
coverage.html
output.log
transcoder.tar.gz

# ==============================================================================
# Dependency & Environment
# ==============================================================================
.env
.env.*
!.env.example
.venv/
config.yaml
config.yml
node_modules/
.node_modules_partial_*/
webui/dist/
frontend/webui/dist/
frontend/webui/node_modules/
backend/internal/control/http/dist/
!backend/internal/control/http/dist/.gitkeep
dist/

# Allow placeholder files needed for `go:embed` compilation/tests when WebUI isn't built.
!backend/internal/control/http/dist/
!backend/internal/control/http/dist/assets/
!backend/internal/control/http/dist/.gitkeep
!backend/internal/control/http/dist/assets/.gitkeep

# ==============================================================================
# Project Specific
# ==============================================================================
data/
.dev/
livetest-data/
*.m3u
*.xml
!android/**/*.xml
*.gz
*.zip
xg2g-main.zip

# OpenAPI Generated Files (Single Source: api/openapi.yaml)
api/openapi-v2-legacy.yaml
api/openapi-v3.yaml
backend/internal/control/http/v3/openapi.yaml

# Keep test golden files
!backend/internal/epg/testdata/*.golden.xml
!backend/internal/epg/testdata/xmltv.golden.xml
!backend/internal/epg/testdata/multi_channel.golden.xml
!backend/internal/epg/testdata/empty.golden.xml
!backend/testdata/contract/

# ==============================================================================
# IDE & System
# ==============================================================================
.vscode/*
**/.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
._*
.Spotlight-V100/
.Trashes/
.cache/
.codex_patch.diff
.copilot-instructions.md
.worktrees/
*.log

# TLS certificates
certs/
picons/
data/picons/*.png
server.pid

# ==============================================================================
# Dev Store / Binary Data
# ==============================================================================
*.sqlite
*.sqlite-journal
*.sqlite-wal

# ==============================================================================
# Ephemeral Debug / One-off Artifacts
# ==============================================================================
curl_output*.json
test_walk.go
fix_helpers.sh
cosign.bundle
*.bundle
