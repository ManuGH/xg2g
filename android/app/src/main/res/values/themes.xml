<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme (Android Studio / Dracula style) -->
    <style name="Theme.Xg2g" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Main colors -->
        <item name="colorPrimary">@color/ide_blue</item>
        <item name="colorOnPrimary">@color/ide_text_primary</item>
        <item name="colorPrimaryContainer">@color/ide_blue</item>
        <item name="colorOnPrimaryContainer">@color/ide_text_primary</item>
        <item name="colorOutline">@color/ide_outline</item>

        <item name="android:windowBackground">@color/ide_background</item>
        <item name="colorSurface">@color/ide_surface</item>
        <item name="colorOnSurface">@color/ide_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/ide_text_secondary</item>

        <item name="colorError">@color/ide_error</item>

        <!-- Components -->
        <item name="editTextStyle">@style/Widget.Xg2g.TextInputEditText</item>
        <item name="textInputStyle">@style/Widget.Xg2g.TextInputLayout</item>
        <item name="materialButtonStyle">@style/Widget.Xg2g.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.Xg2g.Button.Outlined</item>
        <item name="materialCardViewStyle">@style/Widget.Xg2g.CardView</item>

        <!-- Navigation & Status Bar -->
        <item name="android:navigationBarColor">@color/ide_background</item>
        <item name="android:statusBarColor">@color/ide_background</item>
    </style>

    <style name="Widget.Xg2g.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/ide_surface_soft</item>
        <item name="boxStrokeColor">@color/ide_outline</item>
        <item name="boxStrokeErrorColor">@color/ide_error</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="hintTextColor">@color/ide_text_secondary</item>
    </style>

    <style name="Widget.Xg2g.TextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/ide_text_primary</item>
        <item name="android:textColorHint">@color/ide_text_secondary</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <style name="Widget.Xg2g.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">54dp</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="backgroundTint">@color/ide_blue</item>
        <item name="android:textColor">@color/ide_text_primary</item>
    </style>

    <style name="Widget.Xg2g.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">54dp</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="backgroundTint">@color/ide_surface_soft</item>
        <item name="strokeColor">@color/ide_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/ide_text_primary</item>
    </style>

    <style name="Widget.Xg2g.Button.TvRail" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">58dp</item>
        <item name="android:paddingLeft">18dp</item>
        <item name="android:paddingRight">18dp</item>
        <item name="cornerRadius">22dp</item>
        <item name="backgroundTint">@color/ide_surface_panel_soft</item>
        <item name="strokeColor">@color/ide_outline_soft</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/ide_text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">start|center_vertical</item>
    </style>

    <style name="Widget.Xg2g.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/ide_surface_strong</item>
        <item name="strokeColor">@color/ide_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">10dp</item>
    </style>

    <style name="TextAppearance.Xg2g.ShellEyebrow" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textColor">@color/ide_live</item>
    </style>

    <style name="TextAppearance.Xg2g.ShellSupport" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/ide_text_secondary</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.Xg2g.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ide_background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Xg2g</item>
    </style>

    <!-- Theme for Launcher (Fallback) -->
    <style name="Theme.Xg2g.Launcher" parent="Theme.Xg2g" />
</resources>
