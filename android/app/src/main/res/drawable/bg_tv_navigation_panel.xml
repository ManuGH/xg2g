<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="34dp" />
            <gradient
                android:angle="315"
                android:endColor="#EE101A27"
                android:startColor="#F60A121B" />
            <stroke
                android:width="1dp"
                android:color="@color/ide_outline_strong" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="33dp" />
            <gradient
                android:angle="270"
                android:endColor="#00141D2A"
                android:startColor="#242F507A" />
        </shape>
    </item>
</layer-list>
